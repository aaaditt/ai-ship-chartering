# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy relevant lines to backend/.env for local development.
# In production, set these as Environment Variables in the Render dashboard.

# Google Gemini API Key — required for AI negotiation feature
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# CORS — comma-separated list of allowed frontend origins.
# Leave unset locally (defaults to * when unset).
# In production set to your Vercel URL:
# CORS_ORIGINS=https://ai-ship-chartering.vercel.app

# Rate limiting — optional Redis URL.
# If unset, flask-limiter uses in-memory storage (fine for local dev).
# Render's Redis add-on populates this automatically in production.
# REDIS_URL=redis://localhost:6379/0

# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy to frontend/.env.production for local production builds,
# or set in Vercel project dashboard (Environment Variables → Production).
#
# NOT needed for `npm run dev` — Vite's dev-server proxy handles /api.
# VITE_API_URL=https://your-render-service-name.onrender.com
